# =========================================================================
# CẤU HÌNH MẪU CHO ỨNG DỤNG TOÁN HỌC KIOSK
# Hãy copy tệp này thành .env và điền các API Key của bạn để sử dụng.
# =========================================================================

# Khóa API Gemini của bạn (Hỗ trợ nhiều API key ngăn cách bởi dấu phẩy để cân bằng tải)
# Ví dụ: GEMINI_API_KEY=AIzaSyA...,AIzaSyB...
GEMINI_API_KEY=

# Tên tài khoản Google tương ứng với API Key (Dùng để hiển thị trạng thái API Key)
# Số lượng tài khoản phải khớp với số lượng API Key ở trên
# Ví dụ: GEMINI_API_ACCOUNTS=tai_khoan_1,tai_khoan_2
GEMINI_API_ACCOUNTS=

# Cổng mạng chạy Local Web Server (Mặc định: 3000)
PORT=3000

# Mô hình Gemini AI sử dụng (Khuyên dùng: gemini-1.5-flash hoặc gemini-2.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Đường dẫn kiểm tra cập nhật phiên bản mới (Mặc định là repo GitHub của bạn)
# Ví dụ: UPDATE_CHECK_URL=https://raw.githubusercontent.com/<username>/<repo>/main/version.json
UPDATE_CHECK_URL=https://raw.githubusercontent.com/skyprotect/Hoctap/main/version.json

# Google Client ID mặc định phục vụ đăng nhập Google
GOOGLE_CLIENT_ID=1033910156653-jf5787g1hgbfh9v0onqrs84rl36d2qrl.apps.googleusercontent.com

